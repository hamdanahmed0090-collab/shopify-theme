<section class="sly-highlight">
  <div class="sly-wrap">
    <div class="sly-left">
      <div class="sly-number">{{ section.settings.number }}</div>
      <div class="sly-label">{{ section.settings.label }}</div>
      <div class="sly-product">
        {% if section.settings.product_image != blank %}
          {{ section.settings.product_image | image_url: width: 500 | image_tag: loading: 'lazy', alt: section.settings.label }}
        {% else %}
          <span>Product image</span>
        {% endif %}
      </div>
    </div>
    <div class="sly-right">
      <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_italic }}</em></h2>
      <div class="sly-body">{{ section.settings.body }}</div>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#ingredients' }}">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sly-highlight {
    background: {{ section.settings.accent_color }};
    padding: 72px 32px;
    color: #fff;
    font-family: Inter, system-ui, sans-serif;
  }
  #shopify-section-{{ section.id }} .sly-wrap {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 45% 55%;
    gap: 48px;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .sly-number {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(80px, 12vw, 120px);
    font-weight: 800;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .sly-label {
    margin: 8px 0 24px;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 24px;
    font-style: italic;
  }
  #shopify-section-{{ section.id }} .sly-product {
    width: 200px;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: 12px;
    background: #f8e4ec;
    color: #999;
    transform: rotate(-6deg);
    box-shadow: 0 2px 12px rgba(0,0,0,.15);
  }
  #shopify-section-{{ section.id }} .sly-product img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: rotate(6deg) scale(1.08);
  }
  #shopify-section-{{ section.id }} h2 {
    margin: 0 0 20px;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 42px;
    line-height: 1.2;
  }
  #shopify-section-{{ section.id }} .sly-body { line-height: 1.6; }
  #shopify-section-{{ section.id }} .sly-body p { margin: 0 0 16px; }
  #shopify-section-{{ section.id }} a {
    display: inline-flex;
    margin-top: 12px;
    border: 2px solid #fff;
    border-radius: 999px;
    padding: 14px 32px;
    color: #fff;
    text-decoration: none;
    font-weight: 800;
  }
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .sly-wrap { grid-template-columns: 1fr; }
  }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-highlight { padding: 48px 20px; }
    #shopify-section-{{ section.id }} h2 { font-size: 32px; }
  }
</style>

{% schema %}
{
  "name": "TrySolys highlight stat",
  "settings": [
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#E91E63" },
    { "type": "text", "id": "number", "label": "Large number", "default": "24" },
    { "type": "text", "id": "label", "label": "Number label", "default": "Hour Deep Hydration" },
    { "type": "image_picker", "id": "product_image", "label": "Product image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tired, Dull &" },
    { "type": "text", "id": "heading_italic", "label": "Italic heading", "default": "Dry" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Describe the skin concern this product solves in a warm, empathetic voice.</p><p>Introduce the hero ingredient or formula story that makes the result possible.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "See the Ingredient List" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "TrySolys highlight stat" }]
}
{% endschema %}
