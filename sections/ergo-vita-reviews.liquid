{% style %}
  #shopify-section-{{ section.id }} .ergo-reviews {
    padding: 58px 20px;
    background: {{ section.settings.background }};
  }

  #shopify-section-{{ section.id }} .ergo-reviews-container {
    max-width: 1120px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .ergo-reviews-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 28px;
  }

  #shopify-section-{{ section.id }} .ergo-reviews-header h2 {
    margin: 0 0 10px;
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.15;
    font-weight: 900;
    color: {{ section.settings.heading_color }};
  }

  #shopify-section-{{ section.id }} .ergo-reviews-header p {
    margin: 0;
    color: {{ section.settings.text_color }};
    font-size: 16px;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .ergo-reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  #shopify-section-{{ section.id }} .ergo-review-card {
    border: 1px solid #d9e4f2;
    border-radius: 18px;
    padding: 22px;
    background: #fff;
    box-shadow: 0 10px 28px rgba(16, 24, 40, .07);
  }

  #shopify-section-{{ section.id }} .ergo-review-stars {
    color: #f5a524;
    letter-spacing: 1px;
    font-size: 15px;
    margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} .ergo-review-title {
    margin: 0 0 8px;
    color: #101828;
    font-size: 17px;
    line-height: 1.3;
    font-weight: 900;
  }

  #shopify-section-{{ section.id }} .ergo-review-text {
    color: #475467;
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 18px;
  }

  #shopify-section-{{ section.id }} .ergo-reviewer {
    display: flex;
    align-items: center;
    gap: 11px;
  }

  #shopify-section-{{ section.id }} .ergo-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #eef5ff;
    color: #003784;
    display: grid;
    place-items: center;
    font-weight: 900;
  }

  #shopify-section-{{ section.id }} .ergo-reviewer strong {
    display: block;
    font-size: 14px;
    color: #101828;
  }

  #shopify-section-{{ section.id }} .ergo-reviewer span {
    display: block;
    font-size: 12px;
    color: #667085;
    margin-top: 2px;
  }

  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .ergo-reviews-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<section class="ergo-reviews" id="reviews">
  <div class="ergo-reviews-container">
    <div class="ergo-reviews-header">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ergo-reviews-grid">
      {% for block in section.blocks %}
        <article class="ergo-review-card" {{ block.shopify_attributes }}>
          <div class="ergo-review-stars" aria-label="{{ block.settings.stars }} out of 5 stars">
            {% for i in (1..5) %}
              {% if i <= block.settings.stars %}★{% else %}☆{% endif %}
            {% endfor %}
          </div>

          {% if block.settings.title != blank %}
            <h3 class="ergo-review-title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="ergo-review-text">{{ block.settings.text }}</p>
          {% endif %}

          <div class="ergo-reviewer">
            <div class="ergo-avatar">{{ block.settings.name | slice: 0 }}</div>
            <div>
              <strong>{{ block.settings.name }}</strong>
              <span>{{ block.settings.meta }}</span>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ergo Vita reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Customer reviews" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Use real customer feedback from your own store." },
    { "type": "color", "id": "background", "label": "Background", "default": "#f7fbff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#101828" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#475467" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "stars", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "name", "label": "Customer name", "default": "Sophie M." },
        { "type": "text", "id": "meta", "label": "Meta text", "default": "Verified customer" },
        { "type": "text", "id": "title", "label": "Review title", "default": "Very comfortable for daily wear" },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "I wear them for long days and they feel light and supportive." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ergo Vita reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
