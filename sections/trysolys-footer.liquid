<footer class="sly-footer">
  <div class="sly-wrap">
    <div class="sly-top">
      <div class="sly-brand-col">
        <h2>{{ section.settings.brand }}</h2>
        <div>{{ section.settings.tagline }}</div>
        <div class="sly-socials">
          <span></span><span></span><span></span><span></span>
        </div>
      </div>
      {% for block in section.blocks %}
        <div class="sly-col" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.heading }}</h3>
          {% if block.settings.menu != blank %}
            {% for link in block.settings.menu.links %}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {% endfor %}
          {% else %}
            <a href="{{ routes.root_url }}">Home</a>
            <a href="{{ routes.all_products_collection_url }}">Shop</a>
            <a href="{{ routes.search_url }}">Search</a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    <div class="sly-divider"></div>
    <div class="sly-bottom">
      <p>{{ section.settings.copyright }}</p>
      <div class="sly-pays">
        <span>VISA</span><span>MC</span><span>AMEX</span><span>PP</span>
      </div>
    </div>
  </div>
</footer>

<style>
  #shopify-section-{{ section.id }} .sly-footer {
    background: #1a1a1a;
    padding: 72px 32px;
    font-family: Inter, system-ui, sans-serif;
  }
  #shopify-section-{{ section.id }} .sly-wrap { max-width: 1200px; margin: 0 auto; }
  #shopify-section-{{ section.id }} .sly-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3 {
    margin: 0 0 12px;
    color: #fff;
  }
  #shopify-section-{{ section.id }} h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 24px;
  }
  #shopify-section-{{ section.id }} h3 { font-size: 16px; }
  #shopify-section-{{ section.id }} .sly-brand-col div {
    max-width: 320px;
    color: #9a9a9a;
    line-height: 1.6;
  }
  #shopify-section-{{ section.id }} .sly-brand-col p { margin: 0; }
  #shopify-section-{{ section.id }} .sly-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  #shopify-section-{{ section.id }} a {
    color: #9a9a9a;
    text-decoration: none;
    font-size: 14px;
  }
  #shopify-section-{{ section.id }} a:hover { color: #fff; }
  #shopify-section-{{ section.id }} .sly-socials {
    display: flex;
    gap: 12px;
    margin-top: 16px;
  }
  #shopify-section-{{ section.id }} .sly-socials span {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: #6b6b6b;
  }
  #shopify-section-{{ section.id }} .sly-divider {
    height: 1px;
    background: rgba(107,107,107,.4);
    margin-bottom: 24px;
  }
  #shopify-section-{{ section.id }} .sly-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  #shopify-section-{{ section.id }} .sly-bottom p {
    margin: 0;
    color: #9a9a9a;
    font-size: 14px;
  }
  #shopify-section-{{ section.id }} .sly-pays {
    display: flex;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .sly-pays span {
    width: 42px;
    height: 24px;
    display: grid;
    place-items: center;
    border-radius: 3px;
    background: #6b6b6b;
    color: #1a1a1a;
    font-size: 9px;
    font-weight: 800;
  }
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .sly-top { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-footer { padding: 48px 20px; }
    #shopify-section-{{ section.id }} .sly-top { grid-template-columns: 1fr; }
    #shopify-section-{{ section.id }} .sly-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>

{% schema %}
{
  "name": "TrySolys footer",
  "settings": [
    { "type": "text", "id": "brand", "label": "Brand", "default": "TrySolys" },
    { "type": "richtext", "id": "tagline", "label": "Tagline", "default": "<p>Skincare rituals designed for soft, glowing, confident skin.</p>" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "Copyright 2026 TrySolys. All rights reserved." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TrySolys footer",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Shop" } },
        { "type": "menu", "settings": { "heading": "Support" } },
        { "type": "menu", "settings": { "heading": "Contact" } }
      ]
    }
  ]
}
{% endschema %}
