{% style %}
  #shopify-section-{{ section.id }} .ergo-comparison {
    padding: 58px 20px;
    background: {{ section.settings.background }};
  }

  #shopify-section-{{ section.id }} .ergo-comparison-container {
    max-width: 1120px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .ergo-comparison-header {
    max-width: 820px;
    margin: 0 auto 30px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .ergo-comparison-header h2 {
    margin: 0 0 12px;
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.15;
    font-weight: 900;
    color: {{ section.settings.heading_color }};
  }

  #shopify-section-{{ section.id }} .ergo-comparison-header p {
    margin: 0;
    color: {{ section.settings.text_color }};
    font-size: 16px;
    line-height: 1.65;
  }

  #shopify-section-{{ section.id }} .ergo-comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .ergo-compare-card {
    border: 1px solid #d9e4f2;
    border-radius: 18px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 10px 28px rgba(16, 24, 40, .07);
  }

  #shopify-section-{{ section.id }} .ergo-compare-image {
    aspect-ratio: 1.1 / .78;
    background: #eef5ff;
    display: grid;
    place-items: center;
    color: #667085;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .ergo-compare-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .ergo-compare-label {
    padding: 16px 18px;
    font-weight: 900;
    color: #101828;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .ergo-comparison-points {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-top: 20px;
  }

  #shopify-section-{{ section.id }} .ergo-point {
    border: 1px solid #d9e4f2;
    background: #fff;
    border-radius: 14px;
    padding: 16px;
    color: #101828;
    font-size: 14px;
    line-height: 1.45;
    font-weight: 800;
    display: flex;
    gap: 9px;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .ergo-point span:first-child {
    color: #23a455;
    font-weight: 900;
  }

  @media (max-width: 820px) {
    #shopify-section-{{ section.id }} .ergo-comparison-grid,
    #shopify-section-{{ section.id }} .ergo-comparison-points {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<section class="ergo-comparison">
  <div class="ergo-comparison-container">
    <div class="ergo-comparison-header">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="ergo-comparison-grid">
      <div class="ergo-compare-card">
        <div class="ergo-compare-image">
          {% if section.settings.before_image != blank %}
            {{ section.settings.before_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.before_image.alt | default: section.settings.before_label }}
          {% else %}
            <span>Upload comparison image</span>
          {% endif %}
        </div>
        <div class="ergo-compare-label">{{ section.settings.before_label }}</div>
      </div>

      <div class="ergo-compare-card">
        <div class="ergo-compare-image">
          {% if section.settings.after_image != blank %}
            {{ section.settings.after_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.after_image.alt | default: section.settings.after_label }}
          {% else %}
            <span>Upload product benefit image</span>
          {% endif %}
        </div>
        <div class="ergo-compare-label">{{ section.settings.after_label }}</div>
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="ergo-comparison-points">
        {% for block in section.blocks %}
          <div class="ergo-point" {{ block.shopify_attributes }}>
            <span>✓</span>
            <span>{{ block.settings.text }}</span>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Ergo Vita comparison",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why customers choose this product" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "A comfort-first structure helps reduce daily pressure and makes movement feel lighter during long routines." },
    { "type": "image_picker", "id": "before_image", "label": "Left image" },
    { "type": "text", "id": "before_label", "label": "Left label", "default": "Standard footwear" },
    { "type": "image_picker", "id": "after_image", "label": "Right image" },
    { "type": "text", "id": "after_label", "label": "Right label", "default": "Comfort-focused design" },
    { "type": "color", "id": "background", "label": "Background", "default": "#f7fbff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#101828" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#475467" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Benefit point",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Comfort benefit" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ergo Vita comparison",
      "blocks": [
        { "type": "point" },
        { "type": "point" },
        { "type": "point" },
        { "type": "point" }
      ]
    }
  ]
}
{% endschema %}
