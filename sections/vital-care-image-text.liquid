{% comment %}File: sections/vc-image-text.liquid{% endcomment %}
<section class="vc-content-section" style="background: {{ section.settings.background }};">
  <div class="vc-content-container">
    <div class="vc-two-col {% if section.settings.layout == 'image_right' %}vc-reverse{% endif %}">
      <div class="vc-content-image" {% if section.settings.layout == 'image_right' %}style="order:2"{% endif %}>
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1100 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        {% else %}
          Add your lifestyle or product benefit image here
        {% endif %}
      </div>
      <div>
        {% if section.settings.subheading != blank %}<div class="vc-kicker">{{ section.settings.subheading }}</div>{% endif %}
        {% if section.settings.heading != blank %}<h2 class="vc-heading">{{ section.settings.heading }}</h2>{% endif %}
        {% if section.settings.text != blank %}<div class="vc-text">{{ section.settings.text }}</div>{% endif %}

        <div class="vc-check-list">
          {% for block in section.blocks %}
            <div class="vc-check-line" {{ block.shopify_attributes }}>
              <span class="vc-check">✓</span>
              <span>{{ block.settings.text }}</span>
            </div>
          {% else %}
            <div class="vc-check-line"><span class="vc-check">✓</span><span>Add clear product benefit one</span></div>
            <div class="vc-check-line"><span class="vc-check">✓</span><span>Add clear product benefit two</span></div>
            <div class="vc-check-line"><span class="vc-check">✓</span><span>Add clear product benefit three</span></div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VC image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "subheading", "label": "Small heading", "default": "Daily comfort" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Walk with more comfort every day" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Explain your product benefit in a simple conversion-focused paragraph.</p>" },
    { "type": "select", "id": "layout", "label": "Layout", "default": "image_left", "options": [
      { "value": "image_left", "label": "Image left" },
      { "value": "image_right", "label": "Image right" }
    ] },
    { "type": "color", "id": "background", "label": "Background", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Check point",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Comfort-focused benefit point" }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC image with text",
      "blocks": [
        { "type": "point" },
        { "type": "point" },
        { "type": "point" }
      ]
    }
  ]
}
{% endschema %}
