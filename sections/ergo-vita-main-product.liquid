{% comment %}
  Section: Ergo Vita Product Details
  Path: sections/ergo-vita-product-details.liquid

  Clean Shopify Liquid rebuild of the uploaded rendered product details section.
  It uses Shopify product data dynamically instead of competitor product IDs,
  variant IDs, CDN image URLs, or app scripts.
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign product_form_id = 'product-form-' | append: section.id %}

<section
  class="ev-product"
  data-ev-product
  data-section-id="{{ section.id }}"
  data-money-format="{{ shop.money_format | escape }}"
>
  <style>
    #shopify-section-{{ section.id }} .ev-product,
    #shopify-section-{{ section.id }} .ev-product * {
      box-sizing: border-box;
    }

    #shopify-section-{{ section.id }} .ev-product {
      --ev-accent: {{ section.settings.accent_color }};
      --ev-dark: {{ section.settings.text_color }};
      --ev-muted: #667085;
      --ev-border: #e6e8ec;
      --ev-soft: #f7fafb;
      --ev-button: {{ section.settings.button_color }};
      --ev-button-hover: {{ section.settings.button_hover_color }};
      background: {{ section.settings.background_color }};
      color: var(--ev-dark);
      padding: {{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;
      font-family: inherit;
    }

    #shopify-section-{{ section.id }} .ev-product__inner {
      max-width: {{ section.settings.max_width }}px;
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .ev-product__layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(360px, 0.82fr);
      gap: 36px;
      align-items: start;
    }

    #shopify-section-{{ section.id }} .ev-gallery {
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .ev-gallery__main {
      position: relative;
      background: #fff;
      overflow: hidden;
      aspect-ratio: 1 / 1;
      border: 1px solid var(--ev-border);
      border-radius: {{ section.settings.image_radius }}px;
    }

    #shopify-section-{{ section.id }} .ev-gallery__slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      visibility: hidden;
      transition: opacity .22s ease, visibility .22s ease;
      background: #fff;
    }

    #shopify-section-{{ section.id }} .ev-gallery__slide.is-active {
      opacity: 1;
      visibility: visible;
      position: relative;
    }

    #shopify-section-{{ section.id }} .ev-gallery__slide img,
    #shopify-section-{{ section.id }} .ev-gallery__slide video,
    #shopify-section-{{ section.id }} .ev-gallery__slide iframe,
    #shopify-section-{{ section.id }} .ev-gallery__slide model-viewer {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      border-radius: {{ section.settings.image_radius }}px;
    }

    #shopify-section-{{ section.id }} .ev-gallery__placeholder {
      width: 100%;
      height: 100%;
      min-height: 420px;
      display: grid;
      place-items: center;
      text-align: center;
      color: var(--ev-muted);
      background: var(--ev-soft);
      padding: 24px;
    }

    #shopify-section-{{ section.id }} .ev-gallery__arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 4;
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 1px solid #d8dde3;
      background: rgba(255,255,255,.94);
      color: #111;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: .18s ease;
      box-shadow: 0 5px 18px rgba(0,0,0,.08);
    }

    #shopify-section-{{ section.id }} .ev-gallery__arrow:hover {
      background: #f5f5f5;
    }

    #shopify-section-{{ section.id }} .ev-gallery__arrow--prev { left: 12px; }
    #shopify-section-{{ section.id }} .ev-gallery__arrow--next { right: 12px; }

    #shopify-section-{{ section.id }} .ev-gallery__thumbs {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 8px;
      margin-top: 10px;
    }

    #shopify-section-{{ section.id }} .ev-gallery__thumb {
      position: relative;
      border: 1px solid #f2f2f2;
      background: #fff;
      padding: 0;
      aspect-ratio: 1;
      cursor: pointer;
      overflow: hidden;
      border-radius: {{ section.settings.thumb_radius }}px;
      opacity: .76;
      transition: .18s ease;
    }

    #shopify-section-{{ section.id }} .ev-gallery__thumb.is-active,
    #shopify-section-{{ section.id }} .ev-gallery__thumb:hover {
      opacity: 1;
      border-color: var(--ev-accent);
    }

    #shopify-section-{{ section.id }} .ev-gallery__thumb img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    #shopify-section-{{ section.id }} .ev-gallery__play {
      position: absolute;
      top: 5px;
      right: 5px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: rgba(255,255,255,.9);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #111;
      box-shadow: 0 0 0 1px rgba(0,0,0,.08);
    }

    #shopify-section-{{ section.id }} .ev-info {
      display: flex;
      flex-direction: column;
      gap: 9px;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .ev-rating {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
      margin: 5px 0 -5px;
    }

    #shopify-section-{{ section.id }} .ev-rating__stars {
      color: #ffc107;
      font-size: {{ section.settings.star_size }}px;
      letter-spacing: 1px;
      line-height: 1;
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .ev-rating__text,
    #shopify-section-{{ section.id }} .ev-rating__text p {
      margin: 0;
      font-size: {{ section.settings.rating_text_size }}px;
      line-height: 1.3;
      letter-spacing: -.3px;
      color: {{ section.settings.rating_text_color }};
    }

    #shopify-section-{{ section.id }} .ev-rating__text strong {
      font-weight: 700;
    }

    #shopify-section-{{ section.id }} .ev-title {
      margin: {{ section.settings.title_margin_top }}px 0 {{ section.settings.title_margin_bottom }}px;
      font-size: {{ section.settings.title_size }}px;
      line-height: 1.1;
      letter-spacing: -.02em;
      color: {{ section.settings.title_color }};
      font-weight: 800;
    }

    #shopify-section-{{ section.id }} .ev-subtitle,
    #shopify-section-{{ section.id }} .ev-subtitle p {
      margin: 0;
      font-size: {{ section.settings.subtitle_size }}px;
      line-height: 1.45;
      color: {{ section.settings.subtitle_color }};
    }

    #shopify-section-{{ section.id }} .ev-subtitle strong {
      font-weight: 800;
    }

    #shopify-section-{{ section.id }} .ev-benefits {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px 17px;
      max-width: 460px;
      margin: 12px 0 8px;
      padding-right: 8px;
    }

    #shopify-section-{{ section.id }} .ev-benefit {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .ev-benefit__icon {
      flex: 0 0 44px;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: {{ section.settings.benefit_icon_background }};
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .ev-benefit__icon img {
      width: 32px;
      height: 32px;
      object-fit: contain;
      display: block;
    }

    #shopify-section-{{ section.id }} .ev-benefit__fallback {
      font-size: 20px;
    }

    #shopify-section-{{ section.id }} .ev-benefit__text {
      margin: 0;
      font-size: {{ section.settings.benefit_text_size }}px;
      font-weight: 700;
      letter-spacing: -.3px;
      line-height: 1.32;
      color: {{ section.settings.benefit_text_color }};
    }

    #shopify-section-{{ section.id }} .ev-size-guide {
      margin-top: 4px;
    }

    #shopify-section-{{ section.id }} .ev-size-guide__button {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: transparent;
      border: 0;
      padding: 0;
      color: {{ section.settings.size_guide_color }};
      text-decoration: underline;
      font-weight: 700;
      cursor: pointer;
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .ev-price {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 10px;
      margin: 8px 0 4px;
    }

    #shopify-section-{{ section.id }} .ev-price__current {
      color: {{ section.settings.price_color }};
      font-size: {{ section.settings.price_size }}px;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .ev-price__compare {
      color: {{ section.settings.compare_color }};
      font-size: {{ section.settings.compare_size }}px;
      text-decoration: line-through;
    }

    #shopify-section-{{ section.id }} .ev-price__save {
      background: {{ section.settings.save_badge_background }};
      color: {{ section.settings.save_badge_color }};
      border-radius: 5px;
      font-size: 12px;
      line-height: 1;
      font-weight: 800;
      padding: 6px 8px;
    }

    #shopify-section-{{ section.id }} .ev-form {
      margin-top: 4px;
      display: block;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .ev-options {
      display: grid;
      gap: 12px;
      margin: 10px 0;
    }

    #shopify-section-{{ section.id }} .ev-option__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 7px;
      color: {{ section.settings.option_label_color }};
      font-size: {{ section.settings.option_label_size }}px;
      font-weight: 800;
    }

    #shopify-section-{{ section.id }} .ev-option__selected {
      font-weight: 600;
      opacity: .8;
    }

    #shopify-section-{{ section.id }} .ev-option__values {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .ev-option__value {
      position: relative;
      display: inline-flex;
      cursor: pointer;
    }

    #shopify-section-{{ section.id }} .ev-option__value input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    #shopify-section-{{ section.id }} .ev-option__button {
      min-width: 44px;
      min-height: 40px;
      padding: 8px 15px;
      border: 1px solid {{ section.settings.option_border_color }};
      border-radius: {{ section.settings.option_radius }}px;
      background: {{ section.settings.option_background }};
      color: {{ section.settings.option_text_color }};
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: {{ section.settings.option_text_size }}px;
      line-height: 1;
      font-weight: 700;
      transition: .18s ease;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .ev-option__value input:checked + .ev-option__button {
      border-color: {{ section.settings.option_selected_border }};
      background: {{ section.settings.option_selected_background }};
      color: {{ section.settings.option_selected_text }};
      box-shadow: 0 0 0 1px {{ section.settings.option_selected_border }};
    }

    #shopify-section-{{ section.id }} .ev-option__value input:disabled + .ev-option__button {
      opacity: .45;
      text-decoration: line-through;
      cursor: not-allowed;
    }

    #shopify-section-{{ section.id }} .ev-option__swatch {
      min-width: {{ section.settings.swatch_size }}px;
      width: {{ section.settings.swatch_size }}px;
      height: {{ section.settings.swatch_size }}px;
      padding: 0;
      overflow: hidden;
      background-size: cover;
      background-position: center;
    }

    #shopify-section-{{ section.id }} .ev-option__swatch img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    #shopify-section-{{ section.id }} .ev-qty {
      display: {% if section.settings.show_quantity %}flex{% else %}none{% endif %};
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin: 12px 0;
    }

    #shopify-section-{{ section.id }} .ev-qty__label {
      font-size: 14px;
      font-weight: 800;
      color: var(--ev-dark);
    }

    #shopify-section-{{ section.id }} .ev-qty__control {
      height: 42px;
      display: inline-flex;
      align-items: center;
      border: 1px solid var(--ev-border);
      border-radius: 8px;
      overflow: hidden;
      background: #fff;
    }

    #shopify-section-{{ section.id }} .ev-qty__button {
      width: 42px;
      height: 42px;
      border: 0;
      background: #fff;
      cursor: pointer;
      font-size: 18px;
      font-weight: 900;
      color: #111;
    }

    #shopify-section-{{ section.id }} .ev-qty__input {
      width: 54px;
      height: 42px;
      border: 0;
      border-left: 1px solid var(--ev-border);
      border-right: 1px solid var(--ev-border);
      text-align: center;
      font-weight: 800;
      -moz-appearance: textfield;
    }

    #shopify-section-{{ section.id }} .ev-qty__input::-webkit-outer-spin-button,
    #shopify-section-{{ section.id }} .ev-qty__input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    #shopify-section-{{ section.id }} .ev-atc {
      width: 100%;
      min-height: {{ section.settings.button_height }}px;
      border: 1px solid {{ section.settings.button_border_color }};
      border-radius: {{ section.settings.button_radius }}px;
      background: var(--ev-button);
      color: {{ section.settings.button_text_color }};
      font-size: {{ section.settings.button_text_size }}px;
      font-weight: 800;
      letter-spacing: .02em;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: .2s ease;
    }

    #shopify-section-{{ section.id }} .ev-atc:hover {
      background: var(--ev-button-hover);
    }

    #shopify-section-{{ section.id }} .ev-atc:disabled {
      opacity: .55;
      cursor: not-allowed;
    }

    #shopify-section-{{ section.id }} .ev-dynamic-checkout {
      margin-top: 6px;
    }

    #shopify-section-{{ section.id }} .ev-guarantee-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 6px;
      margin: 8px 0 10px;
      font-size: {{ section.settings.guarantee_size }}px;
      color: {{ section.settings.guarantee_color }};
    }

    #shopify-section-{{ section.id }} .ev-guarantee-row__dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: {{ section.settings.guarantee_dot_color }};
      position: relative;
      flex-shrink: 0;
    }

    #shopify-section-{{ section.id }} .ev-guarantee-row__dot:after {
      content: "";
      position: absolute;
      inset: -5px;
      border-radius: 50%;
      border: 1px solid {{ section.settings.guarantee_dot_color }};
      animation: evPulse 1.45s infinite ease-out;
    }

    #shopify-section-{{ section.id }} .ev-payments {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }

    #shopify-section-{{ section.id }} .ev-payment {
      border: 1px solid var(--ev-border);
      background: #fff;
      border-radius: 4px;
      min-width: 45px;
      height: 27px;
      padding: 0 7px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #344054;
      font-size: 10px;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .ev-accordion {
      border-top: 1px solid var(--ev-border);
      margin-top: 14px;
    }

    #shopify-section-{{ section.id }} .ev-accordion__item {
      border-bottom: 1px solid var(--ev-border);
    }

    #shopify-section-{{ section.id }} .ev-accordion__button {
      width: 100%;
      border: 0;
      background: transparent;
      padding: 15px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      color: var(--ev-dark);
      cursor: pointer;
      font-weight: 800;
      text-align: left;
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .ev-accordion__answer {
      display: none;
      padding: 0 0 15px;
      color: #475467;
      font-size: 14px;
      line-height: 1.55;
    }

    #shopify-section-{{ section.id }} .ev-accordion__item.is-open .ev-accordion__answer {
      display: block;
    }

    #shopify-section-{{ section.id }} .ev-size-modal {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 18px;
      background: rgba(0,0,0,.42);
    }

    #shopify-section-{{ section.id }} .ev-size-modal.is-open {
      display: flex;
    }

    #shopify-section-{{ section.id }} .ev-size-modal__box {
      width: min(720px, 100%);
      max-height: 85vh;
      overflow: auto;
      background: #fff;
      border-radius: 14px;
      padding: 22px;
      box-shadow: 0 18px 60px rgba(0,0,0,.18);
    }

    #shopify-section-{{ section.id }} .ev-size-modal__top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 12px;
    }

    #shopify-section-{{ section.id }} .ev-size-modal__top h3 {
      margin: 0;
      font-size: 20px;
    }

    #shopify-section-{{ section.id }} .ev-size-modal__close {
      border: 0;
      background: #f2f4f7;
      width: 36px;
      height: 36px;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .ev-size-modal table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .ev-size-modal th,
    #shopify-section-{{ section.id }} .ev-size-modal td {
      border: 1px solid #e5e7eb;
      padding: 10px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .ev-size-modal th {
      background: #f8fafc;
      font-weight: 800;
    }

    @keyframes evPulse {
      from { opacity: .8; transform: scale(.55); }
      to { opacity: 0; transform: scale(1.8); }
    }

    @media (max-width: 900px) {
      #shopify-section-{{ section.id }} .ev-product__layout {
        grid-template-columns: 1fr;
        gap: 22px;
      }

      #shopify-section-{{ section.id }} .ev-gallery__thumbs {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    @media (max-width: 640px) {
      #shopify-section-{{ section.id }} .ev-product {
        padding-left: 12px;
        padding-right: 12px;
      }

      #shopify-section-{{ section.id }} .ev-title {
        font-size: {{ section.settings.title_size_mobile }}px;
      }

      #shopify-section-{{ section.id }} .ev-benefits {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        padding-right: 0;
      }

      #shopify-section-{{ section.id }} .ev-benefit__icon {
        width: 40px;
        height: 40px;
        flex-basis: 40px;
      }

      #shopify-section-{{ section.id }} .ev-benefit__text {
        font-size: {{ section.settings.benefit_text_size_mobile }}px;
      }

      #shopify-section-{{ section.id }} .ev-gallery__arrow {
        width: 38px;
        height: 38px;
      }

      #shopify-section-{{ section.id }} .ev-option__button {
        min-height: 38px;
        padding: 8px 12px;
        font-size: {{ section.settings.option_text_size_mobile }}px;
      }
    }
  </style>

  <div class="ev-product__inner">
    <div class="ev-product__layout">
      <div class="ev-gallery">
        <div class="ev-gallery__main" data-ev-gallery-main>
          {% if product.media.size > 0 %}
            {% for media in product.media limit: section.settings.media_limit %}
              <div
                class="ev-gallery__slide {% if forloop.first %}is-active{% endif %}"
                data-ev-slide
                data-media-id="{{ media.id }}"
                data-media-index="{{ forloop.index0 }}"
              >
                {% case media.media_type %}
                  {% when 'image' %}
                    {% assign media_alt = media.alt | default: product.title %}
                    {% if forloop.first %}
                      {{ media.preview_image | image_url: width: 1200 | image_tag: loading: 'eager', alt: media_alt, sizes: '(min-width: 990px) 55vw, 100vw' }}
                    {% else %}
                      {{ media.preview_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: media_alt, sizes: '(min-width: 990px) 55vw, 100vw' }}
                    {% endif %}
                  {% when 'video' %}
                    {{ media | media_tag: image_size: '1200x', autoplay: false, controls: true, muted: false }}
                  {% when 'external_video' %}
                    {{ media | external_video_tag }}
                  {% when 'model' %}
                    {{ media | model_viewer_tag }}
                  {% else %}
                    {% assign fallback_alt = media.alt | default: product.title %}
                    {{ media.preview_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: fallback_alt }}
                {% endcase %}
              </div>
            {% endfor %}

            {% if product.media.size > 1 %}
              <button class="ev-gallery__arrow ev-gallery__arrow--prev" type="button" aria-label="Previous image" data-ev-prev>
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="ev-gallery__arrow ev-gallery__arrow--next" type="button" aria-label="Next image" data-ev-next>
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            {% endif %}
          {% else %}
            <div class="ev-gallery__placeholder">
              Upload product images to show the gallery here.
            </div>
          {% endif %}
        </div>

        {% if product.media.size > 1 %}
          <div class="ev-gallery__thumbs" aria-label="Product thumbnails">
            {% for media in product.media limit: section.settings.media_limit %}
              {% assign thumb_alt = media.alt | default: product.title %}
              <button
                class="ev-gallery__thumb {% if forloop.first %}is-active{% endif %}"
                type="button"
                data-ev-thumb
                data-media-id="{{ media.id }}"
                data-media-index="{{ forloop.index0 }}"
                aria-label="Show media {{ forloop.index }}"
              >
                {% if media.preview_image %}
                  {{ media.preview_image | image_url: width: 240 | image_tag: loading: 'lazy', alt: thumb_alt }}
                {% endif %}
                {% if media.media_type == 'video' or media.media_type == 'external_video' %}
                  <span class="ev-gallery__play" aria-hidden="true">
                    <svg viewBox="0 0 10 14" width="8" height="10" fill="currentColor"><path d="M1.482.815A1 1 0 0 0 0 1.69v10.517a1 1 0 0 0 1.525.851L10.54 7.5a1 1 0 0 0-.043-1.728z"/></svg>
                  </span>
                {% endif %}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="ev-info">
        {% if section.settings.show_rating %}
          <div class="ev-rating">
            <div class="ev-rating__stars" aria-label="{{ section.settings.rating_text | strip_html | escape }}">
              {{ section.settings.rating_stars }}
            </div>
            <div class="ev-rating__text">{{ section.settings.rating_text }}</div>
          </div>
        {% endif %}

        <h1 class="ev-title">
          {% if section.settings.custom_title != blank %}
            {{ section.settings.custom_title }}
          {% else %}
            {{ product.title }}
          {% endif %}
        </h1>

        {% if section.settings.subtitle != blank %}
          <div class="ev-subtitle">{{ section.settings.subtitle }}</div>
        {% endif %}

        <div class="ev-benefits">
          {% for block in section.blocks %}
            {% if block.type == 'benefit' %}
              <div class="ev-benefit" {{ block.shopify_attributes }}>
                <div class="ev-benefit__icon">
                  {% if block.settings.icon != blank %}
                    {{ block.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy', alt: block.settings.text }}
                  {% else %}
                    <span class="ev-benefit__fallback">{{ block.settings.fallback_icon }}</span>
                  {% endif %}
                </div>
                <p class="ev-benefit__text">{{ block.settings.text }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        {% if section.settings.show_size_guide %}
          <div class="ev-size-guide">
            <button type="button" class="ev-size-guide__button" data-ev-size-open>
              <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 17 17 4l3 3L7 20z"/><path d="m14 7 3 3"/><path d="m11 10 2 2"/><path d="m8 13 3 3"/></svg>
              {{ section.settings.size_guide_label }}
            </button>
          </div>
        {% endif %}

        <div class="ev-price">
          <span class="ev-price__current" data-ev-price>{{ current_variant.price | money }}</span>
          <span
            class="ev-price__compare"
            data-ev-compare-price
            {% unless current_variant.compare_at_price > current_variant.price %}style="display:none"{% endunless %}
          >
            {{ current_variant.compare_at_price | money }}
          </span>
          <span
            class="ev-price__save"
            data-ev-save-badge
            {% unless current_variant.compare_at_price > current_variant.price %}style="display:none"{% endunless %}
          >
            {{ section.settings.save_text }}
          </span>
        </div>

        {% form 'product', product, id: product_form_id, class: 'ev-form' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-ev-variant-id>

          {% unless product.has_only_default_variant %}
            <div class="ev-options">
              {% for option in product.options_with_values %}
                {% assign option_downcase = option.name | downcase %}
                {% assign is_swatch_option = false %}
                {% if option.position == 1 and section.settings.first_option_as_swatches %}
                  {% assign is_swatch_option = true %}
                {% endif %}
                {% if option_downcase contains 'color' or option_downcase contains 'couleur' %}
                  {% assign is_swatch_option = true %}
                {% endif %}

                <div class="ev-option" data-ev-option data-option-position="{{ option.position }}">
                  {% if section.settings.show_option_labels %}
                    <div class="ev-option__header">
                      <span>{{ option.name }}</span>
                      <span class="ev-option__selected" data-ev-selected-option>{{ option.selected_value }}</span>
                    </div>
                  {% endif %}

                  <div class="ev-option__values" role="radiogroup" aria-label="{{ option.name }}">
                    {% for value in option.values %}
                      {% assign value_available = false %}
                      {% assign value_image = blank %}
                      {% for variant in product.variants %}
                        {% if variant.options contains value %}
                          {% if value_image == blank and variant.featured_media != blank %}
                            {% assign value_image = variant.featured_media.preview_image %}
                          {% endif %}
                          {% if variant.available %}
                            {% assign value_available = true %}
                          {% endif %}
                        {% endif %}
                      {% endfor %}

                      <label class="ev-option__value">
                        <input
                          type="radio"
                          name="options[{{ option.name | escape }}]"
                          value="{{ value | escape }}"
                          {% if option.selected_value == value %}checked{% endif %}
                          {% unless value_available %}disabled{% endunless %}
                          data-ev-option-input
                        >
                        {% if is_swatch_option and value_image != blank %}
                          <span class="ev-option__button ev-option__swatch" title="{{ value | escape }}">
                            {{ value_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: value }}
                          </span>
                        {% else %}
                          <span class="ev-option__button">{{ value }}</span>
                        {% endif %}
                      </label>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endunless %}

          <div class="ev-qty">
            <span class="ev-qty__label">{{ section.settings.quantity_label }}</span>
            <div class="ev-qty__control">
              <button type="button" class="ev-qty__button" data-ev-qty-minus aria-label="Decrease quantity">−</button>
              <input class="ev-qty__input" type="number" name="quantity" value="1" min="1" data-ev-qty>
              <button type="button" class="ev-qty__button" data-ev-qty-plus aria-label="Increase quantity">+</button>
            </div>
          </div>

          <button
            type="submit"
            name="add"
            class="ev-atc"
            data-ev-atc
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {% if current_variant.available %}
              {{ section.settings.add_to_cart_text }}
            {% else %}
              {{ section.settings.sold_out_text }}
            {% endif %}
          </button>

          {% if section.settings.show_dynamic_checkout %}
            <div class="ev-dynamic-checkout">
              {{ form | payment_button }}
            </div>
          {% endif %}
        {% endform %}

        {% if section.settings.guarantee_text != blank %}
          <div class="ev-guarantee-row">
            <span class="ev-guarantee-row__dot"></span>
            <span>{{ section.settings.guarantee_text }}</span>
          </div>
        {% endif %}

        {% if section.settings.show_payment_badges %}
          <div class="ev-payments" aria-label="Payment methods">
            {% assign payment_badges = section.settings.payment_badges | split: ',' %}
            {% for payment in payment_badges %}
              {% assign payment_label = payment | strip %}
              {% if payment_label != blank %}
                <span class="ev-payment">{{ payment_label }}</span>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        {% assign has_accordions = false %}
        {% for block in section.blocks %}
          {% if block.type == 'accordion' %}
            {% assign has_accordions = true %}
          {% endif %}
        {% endfor %}

        {% if has_accordions %}
          <div class="ev-accordion">
            {% for block in section.blocks %}
              {% if block.type == 'accordion' %}
                <div class="ev-accordion__item" {{ block.shopify_attributes }}>
                  <button type="button" class="ev-accordion__button" data-ev-accordion>
                    <span>{{ block.settings.title }}</span>
                    <span>+</span>
                  </button>
                  <div class="ev-accordion__answer">
                    {{ block.settings.content }}
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {% if section.settings.show_size_guide %}
    <div class="ev-size-modal" data-ev-size-modal aria-hidden="true">
      <div class="ev-size-modal__box" role="dialog" aria-modal="true" aria-label="{{ section.settings.size_guide_label | escape }}">
        <div class="ev-size-modal__top">
          <h3>{{ section.settings.size_guide_label }}</h3>
          <button type="button" class="ev-size-modal__close" data-ev-size-close aria-label="Close">×</button>
        </div>
        <div class="ev-size-modal__content">
          {% if section.settings.size_guide_content != blank %}
            {{ section.settings.size_guide_content }}
          {% else %}
            <table>
              <thead>
                <tr>
                  <th>EU</th>
                  <th>Foot length</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>35</td><td>22.5 cm</td></tr>
                <tr><td>36</td><td>23 cm</td></tr>
                <tr><td>37</td><td>23.5 cm</td></tr>
                <tr><td>38</td><td>24 cm</td></tr>
                <tr><td>39</td><td>24.5 cm</td></tr>
                <tr><td>40</td><td>25 cm</td></tr>
                <tr><td>41</td><td>25.5 cm</td></tr>
                <tr><td>42</td><td>26 cm</td></tr>
                <tr><td>43</td><td>26.5 cm</td></tr>
                <tr><td>44</td><td>27 cm</td></tr>
              </tbody>
            </table>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}

  <script type="application/json" data-ev-variants-json>
    {{ product.variants | json }}
  </script>

  <script>
    (() => {
      const root = document.querySelector('#shopify-section-{{ section.id }} [data-ev-product]');
      if (!root || root.dataset.evInitialized === 'true') return;
      root.dataset.evInitialized = 'true';

      const variantsNode = root.querySelector('[data-ev-variants-json]');
      const variants = variantsNode ? JSON.parse(variantsNode.textContent || '[]') : [];

      const slides = [...root.querySelectorAll('[data-ev-slide]')];
      const thumbs = [...root.querySelectorAll('[data-ev-thumb]')];
      const hiddenVariant = root.querySelector('[data-ev-variant-id]');
      const priceEl = root.querySelector('[data-ev-price]');
      const compareEl = root.querySelector('[data-ev-compare-price]');
      const saveEl = root.querySelector('[data-ev-save-badge]');
      const atc = root.querySelector('[data-ev-atc]');
      const qty = root.querySelector('[data-ev-qty]');
      const form = root.querySelector('.ev-form');
      const moneyFormat = root.dataset.moneyFormat || '{{ shop.money_format | escape }}';

      function formatMoney(cents) {
        if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
          return window.Shopify.formatMoney(cents, moneyFormat);
        }

        const value = (Number(cents) || 0) / 100;
        return value.toLocaleString(undefined, {
          style: 'currency',
          currency: '{{ cart.currency.iso_code | default: shop.currency }}'
        });
      }

      function setActiveMediaByIndex(index) {
        if (!slides.length) return;
        const nextIndex = (index + slides.length) % slides.length;

        slides.forEach((slide, i) => {
          slide.classList.toggle('is-active', i === nextIndex);
          const video = slide.querySelector('video');
          if (video && i !== nextIndex) video.pause();
        });

        thumbs.forEach((thumb, i) => {
          thumb.classList.toggle('is-active', i === nextIndex);
        });
      }

      function setActiveMediaById(mediaId) {
        const index = slides.findIndex(slide => String(slide.dataset.mediaId) === String(mediaId));
        if (index >= 0) setActiveMediaByIndex(index);
      }

      function getActiveMediaIndex() {
        const index = slides.findIndex(slide => slide.classList.contains('is-active'));
        return index >= 0 ? index : 0;
      }

      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          setActiveMediaByIndex(Number(thumb.dataset.mediaIndex || 0));
        });
      });

      root.querySelector('[data-ev-prev]')?.addEventListener('click', () => {
        setActiveMediaByIndex(getActiveMediaIndex() - 1);
      });

      root.querySelector('[data-ev-next]')?.addEventListener('click', () => {
        setActiveMediaByIndex(getActiveMediaIndex() + 1);
      });

      function getSelectedOptions() {
        return [...root.querySelectorAll('[data-ev-option]')].map((group) => {
          const checked = group.querySelector('[data-ev-option-input]:checked');
          return checked ? checked.value : null;
        });
      }

      function findVariant() {
        const selected = getSelectedOptions();
        if (!selected.length) return variants[0] || null;

        return variants.find((variant) => {
          return variant.options.every((optionValue, index) => optionValue === selected[index]);
        }) || null;
      }

      function updateSelectedLabels() {
        root.querySelectorAll('[data-ev-option]').forEach((group) => {
          const label = group.querySelector('[data-ev-selected-option]');
          const checked = group.querySelector('[data-ev-option-input]:checked');
          if (label && checked) label.textContent = checked.value;
        });
      }

      function updateVariant() {
        updateSelectedLabels();

        const variant = findVariant();

        if (!variant) {
          if (atc) {
            atc.disabled = true;
            atc.textContent = '{{ section.settings.unavailable_text | escape }}';
          }
          return;
        }

        if (hiddenVariant) hiddenVariant.value = variant.id;

        if (priceEl) priceEl.textContent = formatMoney(variant.price);

        const hasDiscount = variant.compare_at_price && variant.compare_at_price > variant.price;
        if (compareEl) {
          compareEl.style.display = hasDiscount ? '' : 'none';
          if (hasDiscount) compareEl.textContent = formatMoney(variant.compare_at_price);
        }

        if (saveEl) {
          saveEl.style.display = hasDiscount ? '' : 'none';
          if (hasDiscount) {
            const percent = Math.round(((variant.compare_at_price - variant.price) / variant.compare_at_price) * 100);
            saveEl.textContent = '{{ section.settings.save_text | escape }}'.replace('[percent]', percent);
          }
        }

        if (atc) {
          atc.disabled = !variant.available;
          atc.textContent = variant.available ? '{{ section.settings.add_to_cart_text | escape }}' : '{{ section.settings.sold_out_text | escape }}';
        }

        if (variant.featured_media && variant.featured_media.id) {
          setActiveMediaById(variant.featured_media.id);
        }

        const url = new URL(window.location.href);
        url.searchParams.set('variant', variant.id);
        window.history.replaceState({}, '', url.toString());

        form?.dispatchEvent(new CustomEvent('variant:change', { detail: { variant }, bubbles: true }));
      }

      root.querySelectorAll('[data-ev-option-input]').forEach((input) => {
        input.addEventListener('change', updateVariant);
      });

      root.querySelector('[data-ev-qty-minus]')?.addEventListener('click', () => {
        if (!qty) return;
        qty.value = Math.max(1, Number(qty.value || 1) - 1);
      });

      root.querySelector('[data-ev-qty-plus]')?.addEventListener('click', () => {
        if (!qty) return;
        qty.value = Math.max(1, Number(qty.value || 1) + 1);
      });

      root.querySelectorAll('[data-ev-accordion]').forEach((button) => {
        button.addEventListener('click', () => {
          const item = button.closest('.ev-accordion__item');
          if (!item) return;
          item.classList.toggle('is-open');
          const sign = button.querySelector('span:last-child');
          if (sign) sign.textContent = item.classList.contains('is-open') ? '−' : '+';
        });
      });

      const modal = root.querySelector('[data-ev-size-modal]');
      root.querySelector('[data-ev-size-open]')?.addEventListener('click', () => {
        if (!modal) return;
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
      });

      root.querySelector('[data-ev-size-close]')?.addEventListener('click', () => {
        if (!modal) return;
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
      });

      modal?.addEventListener('click', (event) => {
        if (event.target === modal) {
          modal.classList.remove('is-open');
          modal.setAttribute('aria-hidden', 'true');
        }
      });

      updateVariant();
    })();
  </script>
</section>

