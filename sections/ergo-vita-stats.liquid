{% style %}
  #shopify-section-{{ section.id }} .ergo-stats {
    padding: 58px 20px;
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .ergo-stats-container {
    max-width: 1120px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .ergo-stats-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 28px;
  }

  #shopify-section-{{ section.id }} .ergo-stats-header h2 {
    margin: 0 0 10px;
    color: {{ section.settings.heading_color }};
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.15;
    font-weight: 900;
  }

  #shopify-section-{{ section.id }} .ergo-stats-header p {
    margin: 0;
    color: {{ section.settings.text_color }};
    font-size: 16px;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .ergo-stats-grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 4 | at_least: 1 }}, 1fr);
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .ergo-stat-card {
    border: 1px solid #d9e4f2;
    border-radius: 18px;
    background: #fff;
    text-align: center;
    padding: 26px 18px;
    box-shadow: 0 10px 28px rgba(16, 24, 40, .07);
  }

  #shopify-section-{{ section.id }} .ergo-stat-number {
    color: {{ section.settings.accent_color }};
    font-size: clamp(34px, 4vw, 52px);
    line-height: 1;
    font-weight: 900;
    letter-spacing: -1px;
  }

  #shopify-section-{{ section.id }} .ergo-stat-label {
    color: #475467;
    font-size: 14px;
    line-height: 1.45;
    margin-top: 10px;
    font-weight: 800;
  }

  @media (max-width: 800px) {
    #shopify-section-{{ section.id }} .ergo-stats-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<section class="ergo-stats">
  <div class="ergo-stats-container">
    <div class="ergo-stats-header">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="ergo-stats-grid">
      {% for block in section.blocks %}
        <div class="ergo-stat-card" {{ block.shopify_attributes }}>
          <div class="ergo-stat-number">{{ block.settings.number }}{{ block.settings.suffix }}</div>
          <div class="ergo-stat-label">{{ block.settings.label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ergo Vita statistics",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Designed for daily movement" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Replace these numbers with accurate store data or remove the section." },
    { "type": "color", "id": "background", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#101828" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#475467" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#003784" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "30" },
        { "type": "text", "id": "suffix", "label": "Suffix", "default": "days" },
        { "type": "text", "id": "label", "label": "Label", "default": "Return window" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ergo Vita statistics",
      "blocks": [
        { "type": "stat" },
        { "type": "stat" },
        { "type": "stat" }
      ]
    }
  ]
}
{% endschema %}
