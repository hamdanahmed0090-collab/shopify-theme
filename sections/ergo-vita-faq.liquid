{% style %}
  #shopify-section-{{ section.id }} .ergo-faq {
    padding: 58px 20px;
    background: {{ section.settings.background }};
  }

  #shopify-section-{{ section.id }} .ergo-faq-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .ergo-faq-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 30px;
  }

  #shopify-section-{{ section.id }} .ergo-faq-header h2 {
    margin: 0 0 10px;
    color: {{ section.settings.heading_color }};
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.15;
    font-weight: 900;
  }

  #shopify-section-{{ section.id }} .ergo-faq-header p {
    margin: 0;
    color: {{ section.settings.text_color }};
    font-size: 16px;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .ergo-faq-list {
    border: 1px solid #d9e4f2;
    border-radius: 18px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 10px 28px rgba(16, 24, 40, .07);
  }

  #shopify-section-{{ section.id }} .ergo-faq-item + .ergo-faq-item {
    border-top: 1px solid #d9e4f2;
  }

  #shopify-section-{{ section.id }} .ergo-faq-question {
    width: 100%;
    border: 0;
    background: #fff;
    color: #101828;
    padding: 20px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    cursor: pointer;
    text-align: left;
    font-size: 16px;
    font-weight: 900;
  }

  #shopify-section-{{ section.id }} .ergo-faq-icon {
    flex: 0 0 auto;
    font-size: 22px;
    color: #003784;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .ergo-faq-answer {
    display: none;
    padding: 0 22px 20px;
    color: #475467;
    font-size: 15px;
    line-height: 1.65;
  }

  #shopify-section-{{ section.id }} .ergo-faq-answer p {
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .ergo-faq-item.is-open .ergo-faq-answer {
    display: block;
  }

  #shopify-section-{{ section.id }} .ergo-faq-item.is-open .ergo-faq-icon {
    transform: rotate(45deg);
  }
{% endstyle %}

<section class="ergo-faq">
  <div class="ergo-faq-container">
    <div class="ergo-faq-header">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="ergo-faq-list">
      {% for block in section.blocks %}
        <div class="ergo-faq-item {% if forloop.first and section.settings.open_first %}is-open{% endif %}" {{ block.shopify_attributes }}>
          <button class="ergo-faq-question" type="button" aria-expanded="{% if forloop.first and section.settings.open_first %}true{% else %}false{% endif %}">
            <span>{{ block.settings.question }}</span>
            <span class="ergo-faq-icon">+</span>
          </button>
          <div class="ergo-faq-answer">
            {{ block.settings.answer }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
(() => {
  const faq = document.querySelector('#shopify-section-{{ section.id }} .ergo-faq-list');
  if (!faq || faq.dataset.initialized === 'true') return;
  faq.dataset.initialized = 'true';

  faq.querySelectorAll('.ergo-faq-question').forEach(button => {
    button.addEventListener('click', () => {
      const item = button.closest('.ergo-faq-item');
      const isOpen = item.classList.toggle('is-open');
      button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  });
})();
</script>

{% schema %}
{
  "name": "Ergo Vita FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Answer the most common buying questions before checkout." },
    { "type": "checkbox", "id": "open_first", "label": "Open first question by default", "default": true },
    { "type": "color", "id": "background", "label": "Background", "default": "#f7fbff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#101828" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#475467" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Question text" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Answer text.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ergo Vita FAQ",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
