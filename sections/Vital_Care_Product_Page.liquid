<!-- SECTION: hero_with_buy_box -->
<section class="cc-hero">
  <div class="cc-hero-inner">
    <div class="cc-hero-gallery" data-cc-gallery>
      {% assign cc_main_image = current_variant.featured_image | default: product.featured_image %}
      <div class="cc-hero-image{% if cc_main_image != blank %} has-image{% endif %}">
        {% if cc_main_image != blank %}
          {{ cc_main_image | image_url: width: 1400 | image_tag: id: cc_main_image_id, class: 'cc-main-product-image', loading: 'eager', widths: '480, 720, 960, 1200, 1400', sizes: '(min-width: 901px) 50vw, 100vw', alt: product.title }}
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="cc-hero-thumbs" role="list" aria-label="Product images">
          {% for image in product.images limit: 5 %}
            <button
              type="button"
              class="cc-hero-thumb{% if image.id == cc_main_image.id %} is-active{% endif %}"
              data-cc-thumb
              data-image-url="{{ image | image_url: width: 1400 }}"
              data-image-alt="{{ image.alt | default: product.title | escape }}"
              aria-label="View image {{ forloop.index }}"
            >
              {{ image | image_url: width: 180 | image_tag: loading: 'lazy', alt: product.title }}
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="cc-hero-info">
      <p class="cc-hero-breadcrumb">{{ product.vendor }}{% if product.type != blank %} · {{ product.type }}{% endif %}</p>
      <h1 class="cc-hero-headline">{{ product.title }}</h1>
      <div class="cc-hero-rating">
        <span class="cc-hero-stars">★★★★★</span>
        <p class="cc-hero-rating-text">{{ section.settings.rating_text }}</p>
      </div>
      <div class="cc-hero-price-row" data-cc-price-row>
        <p class="cc-hero-price-old{% unless current_variant.compare_at_price > current_variant.price %} is-hidden{% endunless %}" data-cc-compare-price>
          {% if current_variant.compare_at_price > current_variant.price %}{{ current_variant.compare_at_price | money }}{% endif %}
        </p>
        <p class="cc-hero-price-new" data-cc-price>{{ current_variant.price | money }}</p>
        {% assign cc_discount = 0 %}
        {% if current_variant.compare_at_price > current_variant.price %}
          {% assign cc_saved = current_variant.compare_at_price | minus: current_variant.price %}
          {% assign cc_discount = cc_saved | times: 100.0 | divided_by: current_variant.compare_at_price | round %}
        {% endif %}
        <span class="cc-hero-discount{% if cc_discount == 0 %} is-hidden{% endif %}" data-cc-discount>{% if cc_discount > 0 %}-{{ cc_discount }}%{% endif %}</span>
      </div>
      <ul class="cc-hero-benefits">
        {% if section.settings.benefit_1 != blank %}<li class="cc-hero-benefit">{{ section.settings.benefit_1 }}</li>{% endif %}
        {% if section.settings.benefit_2 != blank %}<li class="cc-hero-benefit">{{ section.settings.benefit_2 }}</li>{% endif %}
        {% if section.settings.benefit_3 != blank %}<li class="cc-hero-benefit">{{ section.settings.benefit_3 }}</li>{% endif %}
      </ul>
      {% if section.settings.show_countdown %}
      <div class="cc-hero-countdown">
        <div class="cc-hero-cd-box">
          <span class="cc-hero-cd-num">{{ section.settings.cd_days }}</span>
          <p class="cc-hero-cd-label">Days</p>
        </div>
        <div class="cc-hero-cd-box">
          <span class="cc-hero-cd-num">{{ section.settings.cd_hours }}</span>
          <p class="cc-hero-cd-label">Hrs</p>
        </div>
        <div class="cc-hero-cd-box">
          <span class="cc-hero-cd-num">{{ section.settings.cd_minutes }}</span>
          <p class="cc-hero-cd-label">Min</p>
        </div>
        <div class="cc-hero-cd-box">
          <span class="cc-hero-cd-num">{{ section.settings.cd_seconds }}</span>
          <p class="cc-hero-cd-label">Sec</p>
        </div>
      </div>
      {% endif %}
      {% form 'product', product, id: product_form_id, class: 'cc-product-form', novalidate: 'novalidate' %}
        <div class="cc-product-controls">
          {% if product.has_only_default_variant %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {% else %}
            <div class="cc-field">
              <label for="CCVariant-{{ section.id }}">{{ section.settings.variant_label }}</label>
              <select id="CCVariant-{{ section.id }}" name="id" class="cc-select" data-cc-variant-select>
                {% for variant in product.variants %}
                  <option
                    value="{{ variant.id }}"
                    data-price="{{ variant.price | money | escape }}"
                    data-compare="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | escape }}{% endif %}"
                    data-price-raw="{{ variant.price }}"
                    data-compare-raw="{{ variant.compare_at_price | default: 0 }}"
                    data-available="{{ variant.available }}"
                    data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 1400 }}{% endif %}"
                    data-image-alt="{% if variant.featured_image %}{{ variant.featured_image.alt | default: product.title | escape }}{% endif %}"
                    {% if variant.id == current_variant.id %}selected{% endif %}
                    {% unless variant.available %}disabled{% endunless %}
                  >
                    {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% endif %}
          <div class="cc-field cc-qty-field">
            <label for="CCQuantity-{{ section.id }}">{{ section.settings.qty_label }}</label>
            <input id="CCQuantity-{{ section.id }}" class="cc-qty" type="number" name="quantity" value="1" min="1" inputmode="numeric">
          </div>
        </div>
        <button type="submit" class="cc-hero-cta" data-cc-submit {% unless current_variant.available %}disabled{% endunless %}>
          <span data-cc-submit-text>{% if current_variant.available %}{{ section.settings.cart_text }}{% else %}{{ section.settings.sold_text }}{% endif %}</span>
        </button>
        {{ form | payment_button }}
      {% endform %}
      <div class="cc-hero-pay">
        <span class="cc-hero-pay-icon">VISA</span>
        <span class="cc-hero-pay-icon">MC</span>
        <span class="cc-hero-pay-icon">PAY</span>
      </div>
      <div class="cc-hero-trust">
        <p class="cc-hero-trust-row">{{ section.settings.trust_1 }}</p>
        <p class="cc-hero-trust-row">{{ section.settings.trust_2 }}</p>
      </div>
    </div>
  </div>
</section>

