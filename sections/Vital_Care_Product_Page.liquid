<script>
  (() => {
    const root = document.getElementById('CCRoot-{{ section.id }}');
    if (!root || root.dataset.ccReady === 'true') return;
    root.dataset.ccReady = 'true';

    const mainImage = root.querySelector('.cc-main-product-image');
    root.querySelectorAll('[data-cc-thumb]').forEach((thumb) => {
      thumb.addEventListener('click', () => {
        if (mainImage) {
          mainImage.src = thumb.dataset.imageUrl;
          mainImage.alt = thumb.dataset.imageAlt || mainImage.alt;
        }
        root.querySelectorAll('[data-cc-thumb]').forEach((item) => item.classList.remove('is-active'));
        thumb.classList.add('is-active');
      });
    });

    const variantSelect = root.querySelector('[data-cc-variant-select]');
    const price = root.querySelector('[data-cc-price]');
    const comparePrice = root.querySelector('[data-cc-compare-price]');
    const discount = root.querySelector('[data-cc-discount]');
    const submit = root.querySelector('[data-cc-submit]');
    const submitText = root.querySelector('[data-cc-submit-text]');

    const updateVariant = () => {
      if (!variantSelect) return;
      const option = variantSelect.options[variantSelect.selectedIndex];
      const rawPrice = Number(option.dataset.priceRaw || 0);
      const rawCompare = Number(option.dataset.compareRaw || 0);
      const available = option.dataset.available === 'true';

      if (price) price.textContent = option.dataset.price || '';
      if (comparePrice) {
        comparePrice.textContent = rawCompare > rawPrice ? (option.dataset.compare || '') : '';
        comparePrice.classList.toggle('is-hidden', !(rawCompare > rawPrice));
      }
      if (discount) {
        const percent = rawCompare > rawPrice ? Math.round(((rawCompare - rawPrice) / rawCompare) * 100) : 0;
        discount.textContent = percent ? `-${percent}%` : '';
        discount.classList.toggle('is-hidden', !percent);
      }
      if (submit) submit.disabled = !available;
      if (submitText) submitText.textContent = available ? {{ section.settings.cart_text | json }} : {{ section.settings.sold_text | json }};
      if (mainImage && option.dataset.image) {
        mainImage.src = option.dataset.image;
        if (option.dataset.imageAlt) mainImage.alt = option.dataset.imageAlt;
      }
    };

    variantSelect?.addEventListener('change', updateVariant);

    root.querySelectorAll('.cc-faq-item').forEach((item, index) => {
      const question = item.querySelector('.cc-faq-q');
      const answer = item.querySelector('.cc-faq-a');
      const chevron = item.querySelector('.cc-faq-chevron');
      if (!question || !answer) return;
      if (index > 0) answer.hidden = true;
      question.setAttribute('role', 'button');
      question.setAttribute('tabindex', '0');
      const toggle = () => {
        answer.hidden = !answer.hidden;
        if (chevron) chevron.textContent = answer.hidden ? '+' : '−';
      };
      question.addEventListener('click', toggle);
      question.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          toggle();
        }
      });
    });
  })();
</script>

