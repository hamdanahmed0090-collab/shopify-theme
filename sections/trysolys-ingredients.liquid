<section class="sly-ing" id="ingredients">
  <div class="sly-wrap">
    <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_italic }}</em></h2>
    <div class="sly-grid">
      {% for block in section.blocks %}
        <article class="sly-card" {{ block.shopify_attributes }}>
          <div class="sly-icon">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% else %}
              <span>Icon</span>
            {% endif %}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <div>{{ block.settings.text }}</div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sly-ing {
    background: {{ section.settings.accent_color }};
    padding: 72px 32px;
    color: #fff;
    font-family: Inter, system-ui, sans-serif;
  }
  #shopify-section-{{ section.id }} .sly-wrap { max-width: 1200px; margin: 0 auto; }
  #shopify-section-{{ section.id }} h2 {
    margin: 0 0 48px;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 42px;
    line-height: 1.2;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .sly-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .sly-card {
    border-radius: 12px;
    background: #fff;
    color: #1a1a1a;
    padding: 24px;
    text-align: center;
    box-shadow: 0 2px 12px rgba(233,30,99,.08);
  }
  #shopify-section-{{ section.id }} .sly-icon {
    width: 120px;
    height: 120px;
    margin: 0 auto 20px;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: 12px;
    background: #f8e4ec;
    color: #999;
  }
  #shopify-section-{{ section.id }} .sly-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} h3 { margin: 0 0 10px; font-size: 18px; }
  #shopify-section-{{ section.id }} .sly-card div:last-child {
    color: #6b6b6b;
    line-height: 1.6;
  }
  #shopify-section-{{ section.id }} .sly-card p { margin: 0; }
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .sly-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-ing { padding: 48px 20px; }
    #shopify-section-{{ section.id }} h2 { font-size: 32px; }
  }
</style>

{% schema %}
{
  "name": "TrySolys ingredients",
  "settings": [
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#E91E63" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why It" },
    { "type": "text", "id": "heading_italic", "label": "Italic heading", "default": "Works" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image or icon" },
        { "type": "text", "id": "title", "label": "Title", "default": "Ingredient name" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Explain what this ingredient does and why it matters.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TrySolys ingredients",
      "blocks": [
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "ingredient" }
      ]
    }
  ]
}
{% endschema %}
