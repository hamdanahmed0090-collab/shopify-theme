{% comment %}
  ============================================================
  Section: Media Showcase
  Supports: image, video (hosted), external video (YouTube/Vimeo)
  Location: sections/media-section.liquid
  ============================================================
{% endcomment %}

{{ 'media-section.css' | asset_url | stylesheet_tag }}

<section
  class="media-section"
  id="media-section-{{ section.id }}"
  style="
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="media-section__container {% if section.settings.full_width %}media-section__container--full{% else %}media-section__container--boxed{% endif %}">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="media-section__header" style="text-align: {{ section.settings.text_alignment }};">
        {%- if section.settings.heading != blank -%}
          <h2 class="media-section__heading" style="color: {{ section.settings.heading_color }};">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="media-section__subheading" style="color: {{ section.settings.subheading_color }};">
            {{ section.settings.subheading | escape }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}

      <div
        class="media-section__grid media-section__grid--{{ section.settings.layout }}"
        style="gap: {{ section.settings.media_gap }}px;"
      >

        {%- for block in section.blocks -%}
          <div
            class="media-section__item media-section__item--{{ block.type }}"
            {{ block.shopify_attributes }}
            style="border-radius: {{ section.settings.border_radius }}px; overflow: hidden;"
          >

            {%- case block.type -%}

              {%- when 'image' -%}
                {%- if block.settings.image != blank -%}
                  <div class="media-section__media-wrapper" style="aspect-ratio: {{ block.settings.aspect_ratio }};">
                    {{
                      block.settings.image
                      | image_url: width: 1800
                      | image_tag:
                        loading: 'lazy',
                        class: 'media-section__media media-section__media--image',
                        style: 'object-fit: ' | append: block.settings.object_fit | append: '; width: 100%; height: 100%;',
                        alt: block.settings.image.alt | default: block.settings.caption | escape
                    }}
                  </div>
                {%- else -%}
                  <div class="media-section__placeholder media-section__placeholder--image" style="aspect-ratio: {{ block.settings.aspect_ratio }};">
                    {{ 'image' | placeholder_svg_tag: 'media-section__placeholder-svg' }}
                    <p class="media-section__placeholder-label">Upload an image in the block settings</p>
                  </div>
                {%- endif -%}

                {%- if block.settings.caption != blank -%}
                  <p
                    class="media-section__caption"
                    style="color: {{ block.settings.caption_color }}; text-align: {{ block.settings.caption_align }};"
                  >
                    {{ block.settings.caption | escape }}
                  </p>
                {%- endif -%}


              {%- when 'video' -%}
                {%- if block.settings.video != blank -%}
                  <div class="media-section__media-wrapper" style="aspect-ratio: {{ block.settings.aspect_ratio }};">
                    {{
                      block.settings.video
                      | video_tag:
                        class: 'media-section__media media-section__media--video',
                        autoplay: block.settings.autoplay,
                        loop: block.settings.loop,
                        muted: block.settings.muted,
                        controls: block.settings.show_controls,
                        playsinline: true,
                        style: 'width: 100%; height: 100%; object-fit: cover;'
                    }}
                  </div>
                {%- else -%}
                  <div class="media-section__placeholder media-section__placeholder--video" style="aspect-ratio: {{ block.settings.aspect_ratio }};">
                    {{ 'collection-1' | placeholder_svg_tag: 'media-section__placeholder-svg' }}
                    <p class="media-section__placeholder-label">Upload a video in the block settings</p>
                  </div>
                {%- endif -%}

                {%- if block.settings.caption != blank -%}
                  <p
                    class="media-section__caption"
                    style="color: {{ block.settings.caption_color }}; text-align: {{ block.settings.caption_align }};"
                  >
                    {{ block.settings.caption | escape }}
                  </p>
                {%- endif -%}


              {%- when 'external_video' -%}
                {%- if block.settings.video_url != blank -%}
                  {%- liquid
                    assign video_url = block.settings.video_url
                    assign is_youtube = false
                    assign is_vimeo = false

                    if video_url contains 'youtube.com' or video_url contains 'youtu.be'
                      assign is_youtube = true
                    elsif video_url contains 'vimeo.com'
                      assign is_vimeo = true
                    endif

                    if is_youtube
                      assign video_id = video_url | split: 'v=' | last | split: '&' | first
                      if video_url contains 'youtu.be'
                        assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
                      endif
                      assign embed_url = 'https://www.youtube.com/embed/' | append: video_id
                      if block.settings.autoplay
                        assign embed_url = embed_url | append: '?autoplay=1&mute=1'
                      endif
                    elsif is_vimeo
                      assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first
                      assign embed_url = 'https://player.vimeo.com/video/' | append: video_id
                      if block.settings.autoplay
                        assign embed_url = embed_url | append: '?autoplay=1&muted=1'
                      endif
                    endif
                  -%}

                  <div class="media-section__media-wrapper media-section__media-wrapper--iframe" style="aspect-ratio: {{ block.settings.aspect_ratio }};">
                    {%- if is_youtube or is_vimeo -%}
                      <iframe
                        class="media-section__media media-section__media--external-video"
                        src="{{ embed_url }}"
                        title="{{ block.settings.caption | default: 'Video' | escape }}"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                        style="width: 100%; height: 100%; border: none;"
                      ></iframe>
                    {%- else -%}
                      <p class="media-section__error">Unsupported video URL. Please use a YouTube or Vimeo link.</p>
                    {%- endif -%}
                  </div>
                {%- else -%}
                  <div class="media-section__placeholder" style="aspect-ratio: {{ block.settings.aspect_ratio }};">
                    {{ 'collection-2' | placeholder_svg_tag: 'media-section__placeholder-svg' }}
                    <p class="media-section__placeholder-label">Paste a YouTube or Vimeo URL in the block settings</p>
                  </div>
                {%- endif -%}

                {%- if block.settings.caption != blank -%}
                  <p
                    class="media-section__caption"
                    style="color: {{ block.settings.caption_color }}; text-align: {{ block.settings.caption_align }};"
                  >
                    {{ block.settings.caption | escape }}
                  </p>
                {%- endif -%}

            {%- endcase -%}

          </div>
        {%- endfor -%}

      </div>

    {%- else -%}
      {%- if request.design_mode -%}
        <div class="media-section__empty-state">
          <p>Add image or video blocks using the "Add block" button in the sidebar.</p>
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>


<style>
  #media-section-{{ section.id }} .media-section__heading {
    font-size: {{ section.settings.heading_size }}px;
  }
</style>


{% schema %}
{
  "name": "Media Showcase",
  "tag": "section",
  "class": "shopify-section--media-showcase",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Media"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Images and videos showcased below."
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#555555"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Header text alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Grid layout",
      "options": [
        { "value": "1-col",  "label": "1 column"  },
        { "value": "2-col",  "label": "2 columns" },
        { "value": "3-col",  "label": "3 columns" },
        { "value": "4-col",  "label": "4 columns" },
        { "value": "masonry","label": "Masonry"   }
      ],
      "default": "2-col"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width container",
      "default": false
    },
    {
      "type": "range",
      "id": "media_gap",
      "label": "Gap between items",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Aspect ratio",
          "options": [
            { "value": "1 / 1",   "label": "Square (1:1)"     },
            { "value": "4 / 3",   "label": "Landscape (4:3)"  },
            { "value": "16 / 9",  "label": "Widescreen (16:9)"},
            { "value": "3 / 2",   "label": "Photo (3:2)"      },
            { "value": "9 / 16",  "label": "Portrait (9:16)"  },
            { "value": "auto",    "label": "Natural (auto)"   }
          ],
          "default": "16 / 9"
        },
        {
          "type": "select",
          "id": "object_fit",
          "label": "Image fit",
          "options": [
            { "value": "cover",   "label": "Cover (crop to fill)" },
            { "value": "contain", "label": "Contain (show all)"   },
            { "value": "fill",    "label": "Stretch to fill"      }
          ],
          "default": "cover"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        },
        {
          "type": "color",
          "id": "caption_color",
          "label": "Caption color",
          "default": "#666666"
        },
        {
          "type": "select",
          "id": "caption_align",
          "label": "Caption alignment",
          "options": [
            { "value": "left",   "label": "Left"   },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right"  }
          ],
          "default": "center"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video (uploaded)",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video file",
          "info": "Upload an MP4 or WebM file directly to Shopify."
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Aspect ratio",
          "options": [
            { "value": "1 / 1",   "label": "Square (1:1)"     },
            { "value": "4 / 3",   "label": "Landscape (4:3)"  },
            { "value": "16 / 9",  "label": "Widescreen (16:9)"},
            { "value": "9 / 16",  "label": "Portrait (9:16)"  }
          ],
          "default": "16 / 9"
        },
        {
          "type": "checkbox",
          "id": "autoplay",
          "label": "Autoplay",
          "default": false,
          "info": "Autoplay requires Muted to be enabled."
        },
        {
          "type": "checkbox",
          "id": "muted",
          "label": "Muted",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "loop",
          "label": "Loop",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_controls",
          "label": "Show playback controls",
          "default": true
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        },
        {
          "type": "color",
          "id": "caption_color",
          "label": "Caption color",
          "default": "#666666"
        },
        {
          "type": "select",
          "id": "caption_align",
          "label": "Caption alignment",
          "options": [
            { "value": "left",   "label": "Left"   },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right"  }
          ],
          "default": "center"
        }
      ]
    },
    {
      "type": "external_video",
      "name": "Video (YouTube / Vimeo)",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL",
          "placeholder": "https://www.youtube.com/watch?v=...",
          "info": "Paste a YouTube or Vimeo URL."
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Aspect ratio",
          "options": [
            { "value": "1 / 1",   "label": "Square (1:1)"     },
            { "value": "4 / 3",   "label": "Landscape (4:3)"  },
            { "value": "16 / 9",  "label": "Widescreen (16:9)"},
            { "value": "9 / 16",  "label": "Portrait (9:16)"  }
          ],
          "default": "16 / 9"
        },
        {
          "type": "checkbox",
          "id": "autoplay",
          "label": "Autoplay",
          "default": false,
          "info": "YouTube/Vimeo autoplay requires the video to be muted."
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        },
        {
          "type": "color",
          "id": "caption_color",
          "label": "Caption color",
          "default": "#666666"
        },
        {
          "type": "select",
          "id": "caption_align",
          "label": "Caption alignment",
          "options": [
            { "value": "left",   "label": "Left"   },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right"  }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Media Showcase",
      "blocks": [
        { "type": "image" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
