{% style %}
  #shopify-section-{{ section.id }} .ergo-logos {
    padding: 42px 20px;
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .ergo-logos-container {
    max-width: 1120px;
    margin: 0 auto;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .ergo-logos h2 {
    margin: 0 0 24px;
    font-size: clamp(22px, 3vw, 34px);
    line-height: 1.2;
    font-weight: 900;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .ergo-logo-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .ergo-logo-card {
    min-height: 112px;
    border: 1px solid #d9e4f2;
    border-radius: 16px;
    background: #fff;
    display: grid;
    place-items: center;
    padding: 18px;
    font-size: 15px;
    font-weight: 900;
    color: #003784;
    box-shadow: 0 8px 24px rgba(16, 24, 40, .06);
  }

  #shopify-section-{{ section.id }} .ergo-logo-card img {
    max-width: 100%;
    max-height: 76px;
    object-fit: contain;
    display: block;
  }

  @media (max-width: 800px) {
    #shopify-section-{{ section.id }} .ergo-logo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    #shopify-section-{{ section.id }} .ergo-logo-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<section class="ergo-logos">
  <div class="ergo-logos-container">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="ergo-logo-grid">
      {% for block in section.blocks %}
        <div class="ergo-logo-card" {{ block.shopify_attributes }}>
          {% if block.settings.logo != blank %}
            {{ block.settings.logo | image_url: width: 360 | image_tag: loading: 'lazy', alt: block.settings.logo.alt | default: block.settings.logo_text }}
          {% elsif block.settings.logo_text != blank %}
            <span>{{ block.settings.logo_text }}</span>
          {% else %}
            <span>Logo</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ergo Vita logo strip",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by customers who stay active all day" },
    { "type": "range", "id": "columns_desktop", "label": "Columns on desktop", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "color", "id": "background", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#101828" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo image" },
        { "type": "text", "id": "logo_text", "label": "Fallback text", "default": "Comfort" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ergo Vita logo strip",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
