<section class="sly-how">
  <div class="sly-wrap">
    <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_italic }}</em></h2>
    <div class="sly-list">
      {% for block in section.blocks %}
        <article class="sly-card" {{ block.shopify_attributes }}>
          <span class="sly-num">{{ forloop.index }}</span>
          <div>
            <h3>{{ block.settings.title }}</h3>
            <div>{{ block.settings.text }}</div>
          </div>
          {% if block.settings.badge != blank %}
            <span class="sly-badge">{{ block.settings.badge }}</span>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sly-how {
    background: #fff;
    padding: 72px 32px;
    font-family: Inter, system-ui, sans-serif;
  }
  #shopify-section-{{ section.id }} .sly-wrap { max-width: 720px; margin: 0 auto; }
  #shopify-section-{{ section.id }} h2 {
    margin: 0 0 40px;
    color: #1a1a1a;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 42px;
    line-height: 1.2;
    text-align: center;
  }
  #shopify-section-{{ section.id }} h2 em { color: {{ section.settings.accent_color }}; }
  #shopify-section-{{ section.id }} .sly-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .sly-card {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 20px;
    border: 1px solid #f0d9e2;
    border-radius: 12px;
    background: #fff;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(233,30,99,.08);
  }
  #shopify-section-{{ section.id }} .sly-num {
    width: 32px;
    height: 32px;
    flex: 0 0 32px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: {{ section.settings.accent_color }};
    color: #fff;
    font-weight: 800;
  }
  #shopify-section-{{ section.id }} h3 {
    margin: 0 0 6px;
    color: #1a1a1a;
    font-size: 18px;
  }
  #shopify-section-{{ section.id }} .sly-card div div {
    color: #6b6b6b;
    line-height: 1.6;
  }
  #shopify-section-{{ section.id }} .sly-card p { margin: 0; }
  #shopify-section-{{ section.id }} .sly-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    border-radius: 999px;
    background: {{ section.settings.accent_color }};
    color: #fff;
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 800;
  }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-how { padding: 48px 20px; }
    #shopify-section-{{ section.id }} h2 { font-size: 32px; }
  }
</style>

{% schema %}
{
  "name": "TrySolys how to use",
  "settings": [
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#E91E63" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your Overnight" },
    { "type": "text", "id": "heading_italic", "label": "Italic heading", "default": "Glow" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Cleanse skin" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Apply this step description in clear, simple language.</p>" },
        { "type": "text", "id": "badge", "label": "Badge" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TrySolys how to use",
      "blocks": [
        { "type": "step", "settings": { "title": "Cleanse skin" } },
        { "type": "step", "settings": { "title": "Apply serum", "badge": "NEW" } },
        { "type": "step", "settings": { "title": "Massage in" } },
        { "type": "step", "settings": { "title": "Sleep and glow" } }
      ]
    }
  ]
}
{% endschema %}
