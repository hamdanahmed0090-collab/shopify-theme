<section class="sly-guarantee">
  <div class="sly-wrap">
    <div class="sly-seal">{{ section.settings.seal_text }}</div>
    <h2>{{ section.settings.heading }}</h2>
    <div class="sly-body">{{ section.settings.body }}</div>
    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link | default: '#sly-main' }}">{{ section.settings.button_label }}</a>
    {% endif %}
    {% if section.settings.microtrust != blank %}
      <p>{{ section.settings.microtrust }}</p>
    {% endif %}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sly-guarantee {
    background: {{ section.settings.accent_color }};
    padding: 72px 32px;
    color: #fff;
    font-family: Inter, system-ui, sans-serif;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .sly-wrap {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  #shopify-section-{{ section.id }} .sly-seal {
    width: 96px;
    height: 96px;
    display: grid;
    place-items: center;
    border: 3px solid #fff;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} h2 {
    margin: 0;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 42px;
    line-height: 1.2;
  }
  #shopify-section-{{ section.id }} .sly-body {
    line-height: 1.6;
  }
  #shopify-section-{{ section.id }} .sly-body p,
  #shopify-section-{{ section.id }} p { margin: 0; }
  #shopify-section-{{ section.id }} a {
    min-width: 240px;
    min-height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #fff;
    color: {{ section.settings.accent_color }};
    padding: 0 32px;
    text-decoration: none;
    font-size: 18px;
    font-weight: 800;
    box-shadow: 0 4px 14px rgba(233,30,99,.35);
  }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-guarantee { padding: 48px 20px; }
    #shopify-section-{{ section.id }} h2 { font-size: 28px; }
    #shopify-section-{{ section.id }} a { width: 100%; }
  }
</style>

{% schema %}
{
  "name": "TrySolys guarantee",
  "settings": [
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#E91E63" },
    { "type": "text", "id": "seal_text", "label": "Seal text", "default": "Seal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Money-Back Guarantee" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Try it risk free. If you are not satisfied, contact us within the return window and we will help with your refund.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "CLAIM NOW" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "microtrust", "label": "Microtrust text", "default": "Secure checkout - Free returns - 60-day guarantee" }
  ],
  "presets": [{ "name": "TrySolys guarantee" }]
}
{% endschema %}
