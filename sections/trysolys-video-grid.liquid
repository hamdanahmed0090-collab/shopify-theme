<section class="sly-videos">
  <div class="sly-wrap">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="sly-grid">
      {% for block in section.blocks %}
        <div class="sly-video" {{ block.shopify_attributes }}>
          {% if block.settings.video != blank %}
            {{ block.settings.video | video_tag: autoplay: false, loop: false, muted: false, controls: true }}
          {% elsif block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: block.settings.label }}
            <span class="sly-play" aria-hidden="true">&#9658;</span>
          {% else %}
            <span class="sly-play" aria-hidden="true">&#9658;</span>
            <p>{{ block.settings.label }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sly-videos {
    background: {{ section.settings.background_color }};
    padding: 72px 32px;
    font-family: Inter, system-ui, sans-serif;
  }
  #shopify-section-{{ section.id }} .sly-wrap { max-width: 1200px; margin: 0 auto; }
  #shopify-section-{{ section.id }} h2 {
    margin: 0 0 40px;
    color: #1a1a1a;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 32px;
    font-style: italic;
    font-weight: 600;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .sly-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .sly-video {
    position: relative;
    aspect-ratio: 9 / 16;
    overflow: hidden;
    border-radius: 12px;
    background: #f8e4ec;
    display: grid;
    place-items: center;
    color: #999;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .sly-video img,
  #shopify-section-{{ section.id }} .sly-video video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .sly-play {
    position: absolute;
    inset: auto auto 50% 50%;
    transform: translate(-50%, 50%);
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(255,255,255,.86);
    color: {{ section.settings.accent_color }};
  }
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .sly-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-videos { padding: 48px 20px; }
    #shopify-section-{{ section.id }} h2 { font-size: 26px; }
    #shopify-section-{{ section.id }} .sly-grid { gap: 12px; }
  }
</style>

{% schema %}
{
  "name": "TrySolys video grid",
  "settings": [
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#E91E63" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "See it in action" }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video card",
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "image", "label": "Fallback image" },
        { "type": "text", "id": "label", "label": "Placeholder label", "default": "Vertical video" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TrySolys video grid",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
