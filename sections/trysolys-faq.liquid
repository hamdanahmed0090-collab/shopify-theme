<section class="sly-faq">
  <div class="sly-wrap">
    <h2>{{ section.settings.heading }}</h2>
    <div class="sly-list">
      {% for block in section.blocks %}
        <details class="sly-row" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary>
            <span>{{ block.settings.question }}</span>
            <span aria-hidden="true">+</span>
          </summary>
          <div>{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sly-faq {
    background: #fff;
    padding: 72px 32px;
    font-family: Inter, system-ui, sans-serif;
    color: #1a1a1a;
  }
  #shopify-section-{{ section.id }} .sly-wrap { max-width: 800px; margin: 0 auto; }
  #shopify-section-{{ section.id }} h2 {
    margin: 0 0 40px;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 42px;
    line-height: 1.2;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .sly-row {
    border-bottom: 1px solid #f0d9e2;
    padding: 20px 0;
  }
  #shopify-section-{{ section.id }} summary {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    cursor: pointer;
    list-style: none;
    font-size: 18px;
    font-weight: 700;
  }
  #shopify-section-{{ section.id }} summary::-webkit-details-marker { display: none; }
  #shopify-section-{{ section.id }} details[open] summary span:last-child { transform: rotate(45deg); }
  #shopify-section-{{ section.id }} .sly-row div {
    margin-top: 16px;
    padding-right: 40px;
    color: #6b6b6b;
    line-height: 1.6;
  }
  #shopify-section-{{ section.id }} .sly-row p { margin: 0; }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-faq { padding: 48px 20px; }
    #shopify-section-{{ section.id }} h2 { font-size: 28px; }
    #shopify-section-{{ section.id }} summary { font-size: 16px; }
  }
</style>

{% schema %}
{
  "name": "TrySolys FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How do I use this product?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Add a clear, reassuring answer here.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TrySolys FAQ",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
