<section class="sly-stats">
  <div class="sly-wrap">
    <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_italic }}</em></h2>
    <div class="sly-list">
      {% for block in section.blocks %}
        <div class="sly-row" {{ block.shopify_attributes }}>
          <div class="sly-pct">{{ block.settings.percent }}</div>
          <div class="sly-divider"></div>
          <div>
            <h3>{{ block.settings.claim }}</h3>
            <p>{{ block.settings.source }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.footnote != blank %}
      <p class="sly-foot">{{ section.settings.footnote }}</p>
    {% endif %}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sly-stats {
    background: #fff;
    padding: 72px 32px;
    font-family: Inter, system-ui, sans-serif;
  }
  #shopify-section-{{ section.id }} .sly-wrap { max-width: 720px; margin: 0 auto; }
  #shopify-section-{{ section.id }} h2 {
    margin: 0 0 48px;
    color: #1a1a1a;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 42px;
    line-height: 1.2;
    text-align: center;
  }
  #shopify-section-{{ section.id }} h2 em { color: {{ section.settings.accent_color }}; }
  #shopify-section-{{ section.id }} .sly-row {
    display: flex;
    align-items: center;
    gap: 32px;
    padding: 24px 0;
    border-bottom: 1px solid #f0d9e2;
  }
  #shopify-section-{{ section.id }} .sly-row:last-child { border-bottom: 0; }
  #shopify-section-{{ section.id }} .sly-pct {
    min-width: 120px;
    color: {{ section.settings.accent_color }};
    font-family: "Playfair Display", Georgia, serif;
    font-size: 42px;
    font-weight: 800;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .sly-divider {
    width: 1px;
    align-self: stretch;
    background: #f0d9e2;
  }
  #shopify-section-{{ section.id }} h3 {
    margin: 0 0 6px;
    color: #1a1a1a;
    font-size: 18px;
  }
  #shopify-section-{{ section.id }} .sly-row p {
    margin: 0;
    color: #6b6b6b;
    line-height: 1.5;
  }
  #shopify-section-{{ section.id }} .sly-foot {
    margin: 32px 0 0;
    color: #6b6b6b;
    text-align: center;
    font-size: 12px;
    font-style: italic;
  }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-stats { padding: 48px 20px; }
    #shopify-section-{{ section.id }} h2 { font-size: 32px; }
    #shopify-section-{{ section.id }} .sly-row { gap: 16px; }
    #shopify-section-{{ section.id }} .sly-pct { min-width: 80px; font-size: 32px; }
  }
</style>

{% schema %}
{
  "name": "TrySolys stats list",
  "settings": [
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#E91E63" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Statistics" },
    { "type": "text", "id": "heading_italic", "label": "Italic heading", "default": "Do Not Lie" },
    { "type": "text", "id": "footnote", "label": "Footnote", "default": "Based on customer feedback and product surveys." }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "percent", "label": "Percent", "default": "98%" },
        { "type": "text", "id": "claim", "label": "Claim", "default": "Skin looked more radiant" },
        { "type": "text", "id": "source", "label": "Source detail", "default": "Reported after consistent use." }
      ]
    }
  ],
  "presets": [
    {
      "name": "TrySolys stats list",
      "blocks": [
        { "type": "stat", "settings": { "percent": "98%" } },
        { "type": "stat", "settings": { "percent": "94%" } },
        { "type": "stat", "settings": { "percent": "89%" } }
      ]
    }
  ]
}
{% endschema %}
