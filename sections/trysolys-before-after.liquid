<section class="sly-ba">
  <div class="sly-wrap">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_italic }}</em></h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <div class="sly-sub">{{ section.settings.subheading }}</div>
    {% endif %}
    <div class="sly-images">
      <figure>
        {% if section.settings.before_image != blank %}
          {{ section.settings.before_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.before_label }}
        {% endif %}
        <figcaption>{{ section.settings.before_label }}</figcaption>
      </figure>
      <figure>
        {% if section.settings.after_image != blank %}
          {{ section.settings.after_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.after_label }}
        {% endif %}
        <figcaption>{{ section.settings.after_label }}</figcaption>
      </figure>
    </div>
    {% if section.settings.caption != blank %}
      <p class="sly-caption">{{ section.settings.caption }}</p>
    {% endif %}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sly-ba {
    background: #fff;
    padding: 72px 32px;
    font-family: Inter, system-ui, sans-serif;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .sly-wrap { max-width: 1200px; margin: 0 auto; }
  #shopify-section-{{ section.id }} h2 {
    margin: 0 0 16px;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 42px;
    line-height: 1.2;
    color: #1a1a1a;
  }
  #shopify-section-{{ section.id }} h2 em { color: {{ section.settings.accent_color }}; }
  #shopify-section-{{ section.id }} .sly-sub {
    max-width: 620px;
    margin: 0 auto 40px;
    color: #6b6b6b;
    line-height: 1.6;
  }
  #shopify-section-{{ section.id }} .sly-sub p { margin: 0; }
  #shopify-section-{{ section.id }} .sly-images {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} figure {
    position: relative;
    margin: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 12px;
    background: #f8e4ec;
    box-shadow: 0 2px 12px rgba(233,30,99,.08);
  }
  #shopify-section-{{ section.id }} figure::after {
    content: "Upload image";
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: #999;
  }
  #shopify-section-{{ section.id }} figure:has(img)::after { content: none; }
  #shopify-section-{{ section.id }} img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} figcaption {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 1;
    border-radius: 999px;
    background: {{ section.settings.accent_color }};
    color: #fff;
    padding: 6px 14px;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: .04em;
  }
  #shopify-section-{{ section.id }} .sly-caption {
    margin: 24px 0 0;
    color: #6b6b6b;
    font-size: 14px;
    font-style: italic;
  }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-ba { padding: 48px 20px; }
    #shopify-section-{{ section.id }} h2 { font-size: 32px; }
    #shopify-section-{{ section.id }} .sly-images { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "TrySolys before after",
  "settings": [
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#E91E63" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Instantly transform your" },
    { "type": "text", "id": "heading_italic", "label": "Italic heading", "default": "skin" },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>Show the transformation clearly with close-up before and after imagery.</p>" },
    { "type": "image_picker", "id": "before_image", "label": "Before image" },
    { "type": "image_picker", "id": "after_image", "label": "After image" },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "BEFORE" },
    { "type": "text", "id": "after_label", "label": "After label", "default": "AFTER" },
    { "type": "text", "id": "caption", "label": "Caption", "default": "See the difference" }
  ],
  "presets": [{ "name": "TrySolys before after" }]
}
{% endschema %}
