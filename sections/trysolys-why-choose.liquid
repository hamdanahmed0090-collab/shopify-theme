<section class="sly-why">
  <div class="sly-wrap">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_italic }}</em></h2>
    {% endif %}
    {% if section.settings.intro != blank %}
      <div class="sly-intro">{{ section.settings.intro }}</div>
    {% endif %}
    <div class="sly-card">
      {% for block in section.blocks %}
        <div class="sly-row" {{ block.shopify_attributes }}>
          <span class="sly-icon">{{ block.settings.icon }}</span>
          <div>
            <h3>{{ block.settings.title }}</h3>
            <div>{{ block.settings.text }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sly-why {
    background: {{ section.settings.accent_color }};
    padding: 72px 32px;
    color: #fff;
    font-family: Inter, system-ui, sans-serif;
  }
  #shopify-section-{{ section.id }} .sly-wrap {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} h2 {
    margin: 0;
    max-width: 780px;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 42px;
    line-height: 1.15;
    text-align: center;
  }
  #shopify-section-{{ section.id }} h2 em {
    display: block;
    font-weight: 500;
  }
  #shopify-section-{{ section.id }} .sly-intro {
    max-width: 640px;
    text-align: center;
    line-height: 1.6;
  }
  #shopify-section-{{ section.id }} .sly-intro p { margin: 0; }
  #shopify-section-{{ section.id }} .sly-card {
    width: 100%;
    max-width: 900px;
    margin-top: 16px;
    border-radius: 12px;
    background: #fff;
    color: #1a1a1a;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(233,30,99,.08);
  }
  #shopify-section-{{ section.id }} .sly-row {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 20px 8px;
    border-bottom: 1px solid #f0d9e2;
  }
  #shopify-section-{{ section.id }} .sly-row:last-child { border-bottom: 0; }
  #shopify-section-{{ section.id }} .sly-icon {
    width: 32px;
    height: 32px;
    flex: 0 0 32px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: {{ section.settings.accent_color }};
    color: #fff;
    font-weight: 800;
  }
  #shopify-section-{{ section.id }} h3 {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 800;
  }
  #shopify-section-{{ section.id }} .sly-row div div {
    color: #6b6b6b;
    line-height: 1.55;
  }
  #shopify-section-{{ section.id }} .sly-row p { margin: 0; }
  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .sly-why { padding: 48px 20px; }
    #shopify-section-{{ section.id }} h2 { font-size: 28px; }
    #shopify-section-{{ section.id }} .sly-card { padding: 16px; }
  }
</style>

{% schema %}
{
  "name": "TrySolys why choose",
  "settings": [
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#E91E63" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Women Choose" },
    { "type": "text", "id": "heading_italic", "label": "Italic heading", "default": "The Overnight Glow Ritual" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>A soft, sensorial skincare ritual designed for skin that looks tired, dry, or uneven.</p>" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon text", "default": "*" },
        { "type": "text", "id": "title", "label": "Title", "default": "Deep hydration" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Helps skin feel soft, fresh, and replenished by morning.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TrySolys why choose",
      "blocks": [
        { "type": "feature", "settings": { "icon": "*", "title": "Deep hydration" } },
        { "type": "feature", "settings": { "icon": "+", "title": "Soft glow finish" } },
        { "type": "feature", "settings": { "icon": "o", "title": "Easy night ritual" } }
      ]
    }
  ]
}
{% endschema %}
